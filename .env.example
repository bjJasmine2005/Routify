# ─── MongoDB Atlas ───────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/routify?retryWrites=true&w=majority

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3000
APP_URL=https://your-app-name.onrender.com

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# Use an App Password from Google: https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=you@gmail.com
MAIL_PASS=your_gmail_app_password
MAIL_FROM=you@gmail.com
MAIL_FROM_NAME=Routify

# ─── Super Admin (Platform Admin) ─────────────────────────────────────────────
SUPERADMIN_EMAIL=superadmin@routify.app
SUPERADMIN_PASSWORD=Routify@SuperAdmin2026
