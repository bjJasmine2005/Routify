<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password | Routify</title>
    <meta name="theme-color" content="#2563eb">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🚌</text></svg>">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        * { font-family: 'Inter', sans-serif; }
        body { background: linear-gradient(135deg, #eff6ff 0%, #f8fafc 50%, #f0fdf4 100%); min-height: 100vh; }
        .input-field { border: 1.5px solid #e2e8f0; transition: all 0.2s; }
        .input-field:focus { outline: none; border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,0.1); }
        .glass-card { background: rgba(255,255,255,0.9); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.8); }
    </style>
</head>
<body class="flex min-h-screen items-center justify-center p-4">
    <div class="w-full max-w-md">
        <div class="text-center mb-8">
            <a href="/" class="inline-flex items-center gap-2.5 mb-6">
                <div class="w-10 h-10 bg-blue-600 rounded-xl flex items-center justify-center shadow-lg shadow-blue-200">
                    <i data-lucide="bus" class="w-5 h-5 text-white"></i>
                </div>
                <span class="text-2xl font-black text-slate-900 tracking-tight">Routify</span>
            </a>
        </div>

        <!-- Invalid token state -->
        <div id="invalid-state" style="display:none" class="glass-card rounded-3xl shadow-2xl p-8 text-center">
            <div class="w-16 h-16 bg-red-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
                <i data-lucide="link-2-off" class="w-8 h-8 text-red-500"></i>
            </div>
            <h2 class="text-xl font-black text-slate-900 mb-2">Link Expired</h2>
            <p class="text-slate-500 text-sm mb-6">This reset link has expired or is invalid. Please request a new one.</p>
            <a href="/forgot-password" class="block w-full py-4 bg-blue-600 text-white font-bold rounded-2xl hover:bg-blue-700 transition text-center">Request New Link</a>
        </div>

        <!-- Reset form -->
        <div id="reset-form-card" class="glass-card rounded-3xl shadow-2xl shadow-slate-200/60 p-8 md:p-10">
            <div class="text-center mb-8">
                <div class="w-16 h-16 bg-blue-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
                    <i data-lucide="lock-keyhole" class="w-8 h-8 text-blue-600"></i>
                </div>
                <h1 class="text-2xl font-black text-slate-900 mb-2">Set New Password</h1>
                <p class="text-slate-500 text-sm">Choose a strong password for your account.</p>
            </div>

            <div id="error-msg" style="display:none" class="mb-5 p-4 bg-red-50 border border-red-100 rounded-2xl flex items-start gap-3">
                <i data-lucide="alert-circle" class="w-5 h-5 text-red-500 flex-shrink-0"></i>
                <p class="text-red-700 text-sm" id="error-text"></p>
            </div>

            <form id="reset-form" class="space-y-5">
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">New Password</label>
                    <div class="relative">
                        <i data-lucide="lock" class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
                        <input id="password-input" type="password" required minlength="6" class="input-field w-full pl-11 pr-12 py-3.5 rounded-2xl text-sm" placeholder="Min. 6 characters">
                        <button type="button" onclick="togglePwd('password-input','eye1')" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600">
                            <i data-lucide="eye" class="w-4 h-4" id="eye1"></i>
                        </button>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">Confirm Password</label>
                    <div class="relative">
                        <i data-lucide="lock" class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
                        <input id="confirm-input" type="password" required minlength="6" class="input-field w-full pl-11 pr-12 py-3.5 rounded-2xl text-sm" placeholder="Re-enter password">
                        <button type="button" onclick="togglePwd('confirm-input','eye2')" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600">
                            <i data-lucide="eye" class="w-4 h-4" id="eye2"></i>
                        </button>
                    </div>
                </div>
                <button type="submit" id="submit-btn" class="w-full py-4 bg-blue-600 text-white font-bold rounded-2xl flex items-center justify-center gap-2 hover:bg-blue-700 active:scale-[0.98] transition-all shadow-lg shadow-blue-200">
                    <i data-lucide="check-circle" class="w-4 h-4"></i> Reset Password
                </button>
            </form>
        </div>

        <!-- Success state -->
        <div id="success-state" style="display:none" class="glass-card rounded-3xl shadow-2xl p-8 text-center">
            <div class="w-16 h-16 bg-green-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
                <i data-lucide="check-circle" class="w-8 h-8 text-green-600"></i>
            </div>
            <h2 class="text-xl font-black text-slate-900 mb-2">Password Updated!</h2>
            <p class="text-slate-500 text-sm mb-6">Your password has been reset. You can now sign in.</p>
            <a href="/login" class="block w-full py-4 bg-blue-600 text-white font-bold rounded-2xl hover:bg-blue-700 transition text-center">Sign In Now →</a>
        </div>
    </div>

    <script>
        lucide.createIcons();
        const resetToken = new URLSearchParams(window.location.search).get('token');
        if (!resetToken) {
            document.getElementById('reset-form-card').style.display = 'none';
            document.getElementById('invalid-state').style.display = 'block';
        }

        function togglePwd(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.setAttribute('data-lucide', 'eye-off');
            } else {
                input.type = 'password';
                icon.setAttribute('data-lucide', 'eye');
            }
            lucide.createIcons();
        }

        document.getElementById('reset-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const password = document.getElementById('password-input').value;
            const confirm = document.getElementById('confirm-input').value;
            const errEl = document.getElementById('error-msg');
            const btn = document.getElementById('submit-btn');

            errEl.style.display = 'none';
            if (password !== confirm) {
                document.getElementById('error-text').textContent = 'Passwords do not match.';
                errEl.style.display = 'flex';
                return;
            }

            btn.disabled = true;
            btn.innerHTML = '<div class="w-5 h-5 border-2 border-white border-t-transparent rounded-full animate-spin"></div> Resetting...';

            try {
                const res = await fetch('/api/auth/reset-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ token: resetToken, password })
                });
                const data = await res.json();
                if (!res.ok) {
                    document.getElementById('error-text').textContent = data.error;
                    errEl.style.display = 'flex';
                    btn.disabled = false;
                    btn.innerHTML = '<i data-lucide="check-circle" class="w-4 h-4"></i> Reset Password';
                    lucide.createIcons();
                } else {
                    document.getElementById('reset-form-card').style.display = 'none';
                    document.getElementById('success-state').style.display = 'block';
                }
            } catch {
                document.getElementById('error-text').textContent = 'Connection error. Try again.';
                errEl.style.display = 'flex';
                btn.disabled = false;
                btn.innerHTML = '<i data-lucide="check-circle" class="w-4 h-4"></i> Reset Password';
                lucide.createIcons();
            }
        });
    </script>
</body>
</html>
