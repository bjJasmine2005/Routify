<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Guardian Admin - Oakwood Academy Profile</title>
    <meta name="description" content="Manage institution profile and details.">
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "inverse-surface": "#2d3133",
              "on-tertiary-container": "#31111d",
              "surface-variant": "#dee3e5",
              "on-surface-variant": "#42484a",
              "outline-variant": "#c2c7c9",
              "on-primary-container": "#001f24",
              "on-secondary-container": "#131e21",
              "on-error-container": "#410002",
              "primary-container": "#97f0ff",
              "secondary-container": "#d3e5e9",
              "tertiary-container": "#ffd9e2",
              "error-container": "#ffdad6",
              "on-inverse-surface": "#eff1f2",
              "on-surface": "#191c1d",
              "on-primary": "#ffffff",
              "on-secondary": "#ffffff",
              "on-tertiary": "#ffffff",
              "on-error": "#ffffff",
              "inverse-primary": "#4fd8eb",
              primary: "#006974",
              secondary: "#4a6267",
              tertiary: "#525e62",
              error: "#ba1a1a",
              outline: "#72787a",
              surface: "#f5fafa",
              scrim: "#000000",
            },
          },
        },
      };
    </script>
    <style>
      body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-surface text-on-surface min-h-screen flex">
    <!-- Sidebar -->
    <aside class="w-72 bg-white border-r border-outline-variant flex flex-col sticky top-0 h-screen">
        <div class="p-8 flex items-center gap-3 border-b border-surface-variant">
            <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center text-on-primary shadow-lg shadow-primary/20">
                <span class="material-symbols-outlined">shield_with_heart</span>
            </div>
            <span class="text-2xl font-black tracking-tight text-primary">Guardian</span>
        </div>
        
        <nav class="flex-1 p-6 space-y-2 overflow-y-auto">
            <a href="/superadmin/clients" class="flex items-center gap-4 p-4 rounded-2xl bg-primary-container text-on-primary-container font-bold transition-all duration-300">
                <span class="material-symbols-outlined">corporate_fare</span>
                <span>Clients</span>
            </a>
            <a href="/superadmin/analytics" class="flex items-center gap-4 p-4 rounded-2xl text-on-surface-variant hover:bg-surface-variant/50 font-semibold transition-all duration-300">
                <span class="material-symbols-outlined">monitoring</span>
                <span>Analytics</span>
            </a>
            <a href="/superadmin/system-health" class="flex items-center gap-4 p-4 rounded-2xl text-on-surface-variant hover:bg-surface-variant/50 font-semibold transition-all duration-300">
                <span class="material-symbols-outlined">health_metrics</span>
                <span>System Health</span>
            </a>
        </nav>

        <div class="p-6 border-t border-surface-variant">
            <div class="bg-surface-variant/30 p-4 rounded-2xl flex items-center gap-3">
                <div class="w-10 h-10 bg-secondary rounded-full flex items-center justify-center text-on-secondary">
                    <span class="material-symbols-outlined">person</span>
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-bold truncate">Super Admin</p>
                    <p class="text-xs text-on-surface-variant truncate">admin@guardian.com</p>
                </div>
                <a href="/login" class="text-on-surface-variant hover:text-error transition-colors">
                    <span class="material-symbols-outlined">logout</span>
                </a>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 p-10">
        <div class="max-w-6xl mx-auto">
            <div class="flex items-center gap-4 mb-10">
                <a href="/superadmin/clients" class="w-12 h-12 rounded-2xl bg-white border border-outline-variant flex items-center justify-center text-on-surface-variant hover:bg-primary hover:text-on-primary hover:border-primary transition-all duration-300 shadow-sm">
                    <span class="material-symbols-outlined">arrow_back</span>
                </a>
                <div>
                    <h1 class="text-4xl font-black tracking-tight">Oakwood Academy</h1>
                    <p class="text-on-surface-variant font-medium">Client ID: OAK-2024-001 • Joined Oct 2023</p>
                </div>
                <div class="ml-auto flex gap-3">
                    <button class="px-6 py-3 rounded-2xl bg-white border border-outline-variant font-bold text-on-surface-variant hover:bg-surface-variant transition-all duration-300">
                        Edit Profile
                    </button>
                    <button class="px-6 py-3 rounded-2xl bg-primary text-on-primary font-bold shadow-lg shadow-primary/20 hover:scale-105 transition-all duration-300">
                        Manage Subscription
                    </button>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <!-- Stats Column -->
                <div class="lg:col-span-2 space-y-8">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div class="bg-white p-8 rounded-[2.5rem] border border-outline-variant shadow-sm">
                            <p class="text-on-surface-variant text-sm font-bold uppercase tracking-widest mb-2">Active Buses</p>
                            <h3 class="text-4xl font-black text-primary">24</h3>
                            <p class="text-xs text-green-600 font-bold mt-2 flex items-center gap-1">
                                <span class="material-symbols-outlined text-sm">trending_up</span> +2 this month
                            </p>
                        </div>
                        <div class="bg-white p-8 rounded-[2.5rem] border border-outline-variant shadow-sm">
                            <p class="text-on-surface-variant text-sm font-bold uppercase tracking-widest mb-2">Total Students</p>
                            <h3 class="text-4xl font-black text-secondary">842</h3>
                            <p class="text-xs text-on-surface-variant font-medium mt-2">Across 12 routes</p>
                        </div>
                        <div class="bg-white p-8 rounded-[2.5rem] border border-outline-variant shadow-sm">
                            <p class="text-on-surface-variant text-sm font-bold uppercase tracking-widest mb-2">Safety Score</p>
                            <h3 class="text-4xl font-black text-tertiary">98.4</h3>
                            <p class="text-xs text-green-600 font-bold mt-2 flex items-center gap-1">
                                <span class="material-symbols-outlined text-sm">verified</span> Top 5%
                            </p>
                        </div>
                    </div>

                    <div class="bg-white p-10 rounded-[3rem] border border-outline-variant shadow-sm">
                        <h3 class="text-2xl font-black mb-8">Recent Activity Logs</h3>
                        <div class="space-y-6">
                            <div class="flex gap-6 items-start p-6 rounded-3xl bg-surface transition-all duration-300 hover:scale-[1.01]">
                                <div class="w-12 h-12 bg-primary-container rounded-2xl flex items-center justify-center text-on-primary-container">
                                    <span class="material-symbols-outlined">settings</span>
                                </div>
                                <div class="flex-1">
                                    <p class="font-bold">System Configuration Updated</p>
                                    <p class="text-sm text-on-surface-variant">Admin updated route #4 pickup timings</p>
                                    <p class="text-xs text-outline mt-2">2 hours ago • Admin: Sarah Chen</p>
                                </div>
                            </div>
                            <div class="flex gap-6 items-start p-6 rounded-3xl bg-surface transition-all duration-300 hover:scale-[1.01]">
                                <div class="w-12 h-12 bg-secondary-container rounded-2xl flex items-center justify-center text-on-secondary-container">
                                    <span class="material-symbols-outlined">person_add</span>
                                </div>
                                <div class="flex-1">
                                    <p class="font-bold">New Driver Onboarded</p>
                                    <p class="text-sm text-on-surface-variant">Michael Rodriguez added to fleet</p>
                                    <p class="text-xs text-outline mt-2">Yesterday • Admin: Sarah Chen</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Info Column -->
                <div class="space-y-8">
                    <div class="bg-white p-10 rounded-[3rem] border border-outline-variant shadow-sm">
                        <h3 class="text-2xl font-black mb-8">Account Details</h3>
                        <div class="space-y-8">
                            <div>
                                <p class="text-xs font-bold text-on-surface-variant uppercase tracking-widest mb-2">Primary Contact</p>
                                <p class="font-bold">Dr. Robert Wilson</p>
                                <p class="text-sm text-on-surface-variant">Principal / Director</p>
                            </div>
                            <div>
                                <p class="text-xs font-bold text-on-surface-variant uppercase tracking-widest mb-2">Email Address</p>
                                <p class="font-bold">wilson@oakwood.edu</p>
                            </div>
                            <div>
                                <p class="text-xs font-bold text-on-surface-variant uppercase tracking-widest mb-2">Subscription Plan</p>
                                <div class="mt-2 inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-tertiary-container text-on-tertiary-container font-black text-sm">
                                    <span class="material-symbols-outlined text-sm">workspace_premium</span>
                                    ENTERPRISE
                                </div>
                            </div>
                            <div class="pt-6 border-t border-surface-variant">
                                <p class="text-xs font-bold text-on-surface-variant uppercase tracking-widest mb-4">Quick Actions</p>
                                <div class="grid grid-cols-2 gap-3">
                                    <button class="p-4 rounded-2xl bg-surface border border-outline-variant hover:bg-primary-container transition-colors text-center">
                                        <span class="material-symbols-outlined block mb-1">mail</span>
                                        <span class="text-xs font-bold">Email</span>
                                    </button>
                                    <button class="p-4 rounded-2xl bg-surface border border-outline-variant hover:bg-primary-container transition-colors text-center">
                                        <span class="material-symbols-outlined block mb-1">call</span>
                                        <span class="text-xs font-bold">Call</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="bg-error-container p-8 rounded-[2.5rem] border border-error/20">
                        <h4 class="text-on-error-container font-black mb-2 flex items-center gap-2">
                            <span class="material-symbols-outlined">warning</span>
                            Danger Zone
                        </h4>
                        <p class="text-sm text-on-error-container/80 mb-6">Suspend this client's access to the Guardian platform immediately.</p>
                        <button class="w-full py-4 rounded-2xl bg-error text-on-error font-bold shadow-lg shadow-error/20 hover:scale-[1.02] transition-all">
                            Suspend Account
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </main>
</body>
</html>
