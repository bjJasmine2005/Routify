<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>System Health | Routify Super Admin</title>
  <meta name="description" content="View system health metrics for the Routify platform.">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { --bg:#f0f4f8;--surface:#fff;--surface2:#f8fafc;--border:#e2e8f0;--primary:#2563eb;--text:#0f172a;--muted:#64748b;--sidebar-w:260px;--success:#16a34a;--error:#dc2626;--warning:#d97706; }
    body { font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex; }

    .sidebar { width:var(--sidebar-w);background:#0f172a;display:flex;flex-direction:column;position:fixed;top:0;left:0;bottom:0;z-index:100; }
    .sidebar-logo { padding:24px 20px;border-bottom:1px solid rgba(255,255,255,0.07);display:flex;align-items:center;gap:12px; }
    .logo-icon { width:40px;height:40px;background:linear-gradient(135deg,#3b82f6,#8b5cf6);border-radius:10px;display:flex;align-items:center;justify-content:center; }
    .logo-icon .material-symbols-outlined { font-size:20px;color:white; }
    .logo-text { font-size:18px;font-weight:900;color:white; }
    .logo-badge { font-size:9px;font-weight:700;color:#fbbf24;background:rgba(251,191,36,0.15);border:1px solid rgba(251,191,36,0.3);border-radius:4px;padding:2px 6px;letter-spacing:0.05em;margin-left:auto; }
    .sidebar-nav { flex:1;padding:16px 12px;overflow-y:auto; }
    .nav-section-label { font-size:10px;font-weight:700;color:rgba(255,255,255,0.3);letter-spacing:0.1em;text-transform:uppercase;padding:8px 8px 4px; }
    .nav-item { display:flex;align-items:center;gap:12px;padding:10px 12px;border-radius:10px;color:rgba(255,255,255,0.6);font-size:14px;font-weight:500;text-decoration:none;transition:all 0.15s;margin-bottom:2px; }
    .nav-item:hover { background:rgba(255,255,255,0.07);color:white; }
    .nav-item.active { background:rgba(59,130,246,0.2);color:#93c5fd; }
    .nav-item .material-symbols-outlined { font-size:20px; }
    .sidebar-footer { padding:16px 12px;border-top:1px solid rgba(255,255,255,0.07); }
    .admin-profile { display:flex;align-items:center;gap:10px;padding:10px 12px; }
    .avatar { width:36px;height:36px;background:linear-gradient(135deg,#f59e0b,#ef4444);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:800;color:white; }
    .admin-info { flex:1;min-width:0; }
    .admin-name { font-size:13px;font-weight:700;color:white;white-space:nowrap;overflow:hidden;text-overflow:ellipsis; }
    .admin-role { font-size:11px;color:rgba(255,255,255,0.4); }
    .logout-btn { background:none;border:none;cursor:pointer;color:rgba(255,255,255,0.3);padding:4px;display:flex;align-items:center;transition:color 0.15s; }
    .logout-btn:hover { color:#ef4444; }
    .logout-btn .material-symbols-outlined { font-size:20px; }

    .main { margin-left:var(--sidebar-w);flex:1; }
    .topbar { background:var(--surface);border-bottom:1px solid var(--border);padding:16px 32px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50; }
    .topbar h1 { font-size:20px;font-weight:800; }
    .topbar p { font-size:13px;color:var(--muted);margin-top:2px; }
    .refresh-btn { background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:8px 16px;font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:6px;color:var(--text);font-family:'Inter',sans-serif; }
    .refresh-btn:hover { background:var(--border); }
    .refresh-btn .material-symbols-outlined { font-size:16px; }

    .content { padding:28px 32px; }
    .section-title { font-size:11px;font-weight:700;color:var(--muted);letter-spacing:0.08em;text-transform:uppercase;margin-bottom:12px; }

    /* Overall status banner */
    .status-banner { border-radius:14px;padding:20px 24px;display:flex;align-items:center;gap:16px;margin-bottom:24px; }
    .status-banner.ok { background:linear-gradient(135deg,#f0fdf4,#dcfce7);border:1px solid #bbf7d0; }
    .status-banner.warn { background:linear-gradient(135deg,#fffbeb,#fef3c7);border:1px solid #fde68a; }
    .status-banner-icon { width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center; }
    .status-banner-icon.ok { background:#dcfce7; }
    .status-banner-icon .material-symbols-outlined { font-size:24px; }
    .status-banner-title { font-size:18px;font-weight:800; }
    .status-banner-sub { font-size:13px;color:var(--muted);margin-top:2px; }
    .uptime-badge { margin-left:auto;background:rgba(22,163,74,0.1);border:1px solid rgba(22,163,74,0.2);border-radius:100px;padding:6px 14px;font-size:13px;font-weight:700;color:var(--success); }

    .service-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:24px; }
    .service-card { background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:20px;display:flex;align-items:center;gap:16px; }
    .service-icon { width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0; }
    .service-icon .material-symbols-outlined { font-size:22px; }
    .service-name { font-size:15px;font-weight:700; }
    .service-sub { font-size:12px;color:var(--muted);margin-top:2px; }
    .status-pill { display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:100px;font-size:11px;font-weight:700;margin-top:6px; }
    .status-pill.ok { background:#dcfce7;color:#15803d; }
    .status-pill.ok::before { content:'●';font-size:8px; }
    .status-pill.warn { background:#fef3c7;color:#b45309; }
    .status-pill.warn::before { content:'●';font-size:8px; }
    .status-pill.error { background:#fef2f2;color:#dc2626; }
    .status-pill.error::before { content:'●';font-size:8px; }

    .metrics-grid { display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px; }
    .metric-card { background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:24px; }
    .metric-title { font-size:15px;font-weight:800;margin-bottom:16px; }
    .metric-row { display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border); }
    .metric-row:last-child { border-bottom:none; }
    .metric-label { font-size:13px;color:var(--muted);display:flex;align-items:center;gap:8px; }
    .metric-label .material-symbols-outlined { font-size:16px; }
    .metric-value { font-size:14px;font-weight:700; }

    .log-card { background:var(--surface);border:1px solid var(--border);border-radius:14px;overflow:hidden; }
    .log-header { padding:16px 24px;border-bottom:1px solid var(--border);font-size:15px;font-weight:800; }
    .log-item { display:flex;align-items:flex-start;gap:12px;padding:12px 24px;border-bottom:1px solid var(--border);font-size:13px; }
    .log-item:last-child { border-bottom:none; }
    .log-dot { width:8px;height:8px;border-radius:50%;margin-top:4px;flex-shrink:0; }
    .log-dot.ok { background:#22c55e; }
    .log-dot.info { background:#3b82f6; }
    .log-dot.warn { background:#f59e0b; }
    .log-time { color:var(--muted);font-size:11px;white-space:nowrap;margin-top:1px; }
    .log-msg { flex:1;color:var(--text);font-weight:500; }

    .check-icon-ok { color:var(--success); }
    .check-icon-warn { color:var(--warning); }
    .svc-ok { background:#f0fdf4; }
    .svc-warn { background:#fffbeb; }
    .svc-err { background:#fef2f2; }

    /* ─── Hamburger + Mobile Sidebar ───────────────────── */
    .menu-toggle {
      display: none;
      background: none;
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 6px 10px;
      cursor: pointer;
      color: var(--text);
      align-items: center;
    }
    .menu-toggle .material-symbols-outlined { font-size: 22px; }
    .sidebar-overlay {
      display: none;
      position: fixed; inset: 0;
      background: rgba(0,0,0,0.5);
      z-index: 90;
      backdrop-filter: blur(2px);
    }
    .sidebar-overlay.show { display: block; }

    @media (max-width: 1024px) {
      :root { --sidebar-w: 220px; }
      .service-grid { grid-template-columns: repeat(2, 1fr); }
      .metrics-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 768px) {
      :root { --sidebar-w: 260px; }
      .sidebar {
        transform: translateX(-100%);
        transition: transform 0.3s ease;
        z-index: 110;
      }
      .sidebar.mobile-open { transform: translateX(0); }
      .main { margin-left: 0 !important; }
      .menu-toggle { display: flex; }
      .topbar { padding: 12px 16px; gap: 12px; }
      .content { padding: 16px; }
      .service-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; margin-bottom: 16px; }
      .metrics-grid { grid-template-columns: 1fr; gap: 16px; margin-bottom: 16px; }
      .status-banner { flex-wrap: wrap; gap: 12px; padding: 16px; }
      .uptime-badge { margin-left: 0; }
    }
    @media (max-width: 480px) {
      .service-grid { grid-template-columns: 1fr; }
      .service-card { padding: 14px; }
      .status-banner-title { font-size: 15px; }
      .topbar h1 { font-size: 17px; }
      .topbar p { display: none; }
    }
  </style>
</head>
<body>
  <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
      <div class="logo-icon"><span class="material-symbols-outlined">directions_bus</span></div>
      <span class="logo-text">Routify</span>
      <span class="logo-badge">SUDO</span>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-section-label">Platform</div>
      <a href="/superadmin/dashboard" class="nav-item"><span class="material-symbols-outlined">dashboard</span>Dashboard</a>
      <a href="/superadmin/clients" class="nav-item"><span class="material-symbols-outlined">corporate_fare</span>Institutions</a>
      <a href="/superadmin/analytics" class="nav-item"><span class="material-symbols-outlined">monitoring</span>Analytics</a>
      <a href="/superadmin/system-health" class="nav-item active"><span class="material-symbols-outlined">health_metrics</span>System Health</a>
    </nav>
    <div class="sidebar-footer">
      <div class="admin-profile">
        <div class="avatar">SA</div>
        <div class="admin-info">
          <div class="admin-name" id="adminEmail">Super Admin</div>
          <div class="admin-role">Platform Administrator</div>
        </div>
        <button class="logout-btn" onclick="logout()"><span class="material-symbols-outlined">logout</span></button>
      </div>
    </div>
  </aside>

  <div class="main">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px;">
        <button class="menu-toggle" onclick="toggleSidebar()" aria-label="Toggle menu">
          <span class="material-symbols-outlined">menu</span>
        </button>
        <div>
          <h1>System Health</h1>
          <p>Platform infrastructure status and diagnostics</p>
        </div>
      </div>
      <button class="refresh-btn" onclick="loadHealth()">
        <span class="material-symbols-outlined">refresh</span>
        Refresh
      </button>
    </div>

    <div class="content">
      <!-- Overall Status -->
      <div class="status-banner ok" id="statusBanner">
        <div class="status-banner-icon ok">
          <span class="material-symbols-outlined" style="color:var(--success)">check_circle</span>
        </div>
        <div>
          <div class="status-banner-title">All Systems Operational</div>
          <div class="status-banner-sub" id="statusSub">Checking services...</div>
        </div>
        <div class="uptime-badge" id="uptimeBadge">● Checking...</div>
      </div>

      <!-- Services -->
      <div class="section-title">Services</div>
      <div class="service-grid">
        <div class="service-card">
          <div class="service-icon svc-ok"><span class="material-symbols-outlined" style="color:var(--success)">storage</span></div>
          <div>
            <div class="service-name">MongoDB Atlas</div>
            <div class="service-sub">Primary database</div>
            <div class="status-pill ok" id="dbStatus">Connected</div>
          </div>
        </div>
        <div class="service-card">
          <div class="service-icon svc-ok"><span class="material-symbols-outlined" style="color:#3b82f6">cloud</span></div>
          <div>
            <div class="service-name">Express Server</div>
            <div class="service-sub">API layer</div>
            <div class="status-pill ok" id="apiStatus">Running</div>
          </div>
        </div>
        <div class="service-card">
          <div class="service-icon svc-ok"><span class="material-symbols-outlined" style="color:#8b5cf6">wifi</span></div>
          <div>
            <div class="service-name">WebSocket (Socket.IO)</div>
            <div class="service-sub">Real-time tracking</div>
            <div class="status-pill ok" id="wsStatus">Active</div>
          </div>
        </div>
        <div class="service-card">
          <div class="service-icon svc-ok"><span class="material-symbols-outlined" style="color:#f59e0b">email</span></div>
          <div>
            <div class="service-name">Email Service</div>
            <div class="service-sub">Gmail SMTP</div>
            <div class="status-pill ok" id="emailStatus">Configured</div>
          </div>
        </div>
        <div class="service-card">
          <div class="service-icon svc-ok"><span class="material-symbols-outlined" style="color:#10b981">location_on</span></div>
          <div>
            <div class="service-name">Nominatim API</div>
            <div class="service-sub">Geocoding service</div>
            <div class="status-pill ok">External</div>
          </div>
        </div>
        <div class="service-card">
          <div class="service-icon svc-ok"><span class="material-symbols-outlined" style="color:#ec4899">route</span></div>
          <div>
            <div class="service-name">OSRM Routing</div>
            <div class="service-sub">Route optimization</div>
            <div class="status-pill ok">External</div>
          </div>
        </div>
      </div>

      <!-- Metrics -->
      <div class="section-title">Database Metrics</div>
      <div class="metrics-grid">
        <div class="metric-card">
          <div class="metric-title">📊 Collection Counts</div>
          <div class="metric-row">
            <div class="metric-label"><span class="material-symbols-outlined">corporate_fare</span>Institutions</div>
            <div class="metric-value" id="mInstitutions">—</div>
          </div>
          <div class="metric-row">
            <div class="metric-label"><span class="material-symbols-outlined">person</span>Users (All Roles)</div>
            <div class="metric-value" id="mUsers">—</div>
          </div>
          <div class="metric-row">
            <div class="metric-label"><span class="material-symbols-outlined">groups</span>Students</div>
            <div class="metric-value" id="mStudents">—</div>
          </div>
          <div class="metric-row">
            <div class="metric-label"><span class="material-symbols-outlined">directions_bus</span>Vehicles</div>
            <div class="metric-value" id="mVehicles">—</div>
          </div>
          <div class="metric-row">
            <div class="metric-label"><span class="material-symbols-outlined">route</span>Routes</div>
            <div class="metric-value" id="mRoutes">—</div>
          </div>
        </div>
        <div class="metric-card">
          <div class="metric-title">🚌 Trip Activity</div>
          <div class="metric-row">
            <div class="metric-label"><span class="material-symbols-outlined">local_activity</span>Total Trips Ever</div>
            <div class="metric-value" id="mTripsTotal">—</div>
          </div>
          <div class="metric-row">
            <div class="metric-label"><span class="material-symbols-outlined">task_alt</span>Completed Trips</div>
            <div class="metric-value" id="mTripsCompleted">—</div>
          </div>
          <div class="metric-row">
            <div class="metric-label"><span class="material-symbols-outlined">radio_button_checked</span>Active Right Now</div>
            <div class="metric-value" id="mTripsActive" style="color:var(--success)">—</div>
          </div>
          <div class="metric-row">
            <div class="metric-label"><span class="material-symbols-outlined">campaign</span>Total Notices</div>
            <div class="metric-value" id="mNotices">—</div>
          </div>
          <div class="metric-row">
            <div class="metric-label"><span class="material-symbols-outlined">how_to_reg</span>Attendance Records</div>
            <div class="metric-value" id="mAttendance">—</div>
          </div>
        </div>
      </div>

      <!-- System Log -->
      <div class="section-title">System Events</div>
      <div class="log-card">
        <div class="log-header">Recent Activity Log</div>
        <div id="systemLog">
          <div style="padding:40px;text-align:center;color:var(--muted)">Loading system events...</div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const token = localStorage.getItem('superadmin_token');
    if (!token) window.location.href = '/superadmin/login';
    try { const p = JSON.parse(atob(token.split('.')[1])); document.getElementById('adminEmail').textContent = p.email || 'Super Admin'; } catch(e){}
    const headers = { 'Authorization': `Bearer ${token}` };
    function logout() { localStorage.removeItem('superadmin_token'); window.location.href = '/superadmin/login'; }

    async function loadHealth() {
      try {
        const [statsRes, healthRes] = await Promise.all([
          fetch('/api/superadmin/stats', { headers }),
          fetch('/api/superadmin/health', { headers })
        ]);
        if (statsRes.status === 401) { logout(); return; }
        const stats = await statsRes.json();
        const health = await healthRes.json();

        // Update metrics
        document.getElementById('mInstitutions').textContent = stats.totalInstitutions ?? '—';
        document.getElementById('mUsers').textContent = (stats.totalDrivers ?? 0) + (stats.totalInstitutions ?? 0);
        document.getElementById('mStudents').textContent = stats.totalStudents ?? '—';
        document.getElementById('mVehicles').textContent = stats.totalVehicles ?? '—';
        document.getElementById('mRoutes').textContent = stats.totalRoutes ?? '—';
        document.getElementById('mTripsTotal').textContent = (stats.totalTrips ?? 0).toLocaleString();
        document.getElementById('mTripsCompleted').textContent = (stats.completedTrips ?? 0).toLocaleString();
        document.getElementById('mTripsActive').textContent = stats.activeTrips ?? 0;
        document.getElementById('mNotices').textContent = stats.totalNotices ?? '—';
        document.getElementById('mAttendance').textContent = (stats.totalAttendance ?? 0).toLocaleString();

        // Update status
        const dbOk = health.mongodb === 'connected';
        document.getElementById('dbStatus').className = `status-pill ${dbOk ? 'ok' : 'error'}`;
        document.getElementById('dbStatus').textContent = dbOk ? 'Connected' : 'Disconnected';

        const uptime = health.uptimeSeconds ? formatUptime(health.uptimeSeconds) : 'Unknown';
        document.getElementById('uptimeBadge').textContent = `● Uptime: ${uptime}`;
        document.getElementById('statusSub').textContent = `Last checked: ${new Date().toLocaleTimeString()} · Node.js ${health.nodeVersion || 'unknown'} · ${uptime} uptime`;

        // System log based on real data
        const now = new Date();
        const logs = [
          { type: 'ok', msg: `MongoDB Atlas: Connected · ${stats.totalInstitutions} institutions loaded`, time: 'Just now' },
          { type: 'info', msg: `Platform: ${stats.activeTrips} active trip(s) in progress`, time: 'Live' },
          { type: 'ok', msg: `Email service: Gmail SMTP configured and operational`, time: 'Active' },
          { type: 'info', msg: `WebSocket: Real-time tracking enabled for all institutions`, time: 'Running' },
          { type: 'ok', msg: `Total ${stats.totalStudents} students tracked · ${stats.totalDrivers} drivers registered`, time: 'Platform stats' },
          { type: 'info', msg: `${(stats.totalTrips||0).toLocaleString()} total trips completed on platform`, time: 'All time' },
        ];

        document.getElementById('systemLog').innerHTML = logs.map(log => `
          <div class="log-item">
            <div class="log-dot ${log.type}"></div>
            <div class="log-msg">${log.msg}</div>
            <div class="log-time">${log.time}</div>
          </div>`).join('');

      } catch(e) {
        console.error(e);
        document.getElementById('statusBanner').className = 'status-banner warn';
      }
    }

    function formatUptime(seconds) {
      const h = Math.floor(seconds / 3600);
      const m = Math.floor((seconds % 3600) / 60);
      const s = Math.floor(seconds % 60);
      if (h > 0) return `${h}h ${m}m`;
      if (m > 0) return `${m}m ${s}s`;
      return `${s}s`;
    }

    loadHealth();
    setInterval(loadHealth, 30000);

    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('mobile-open');
      document.getElementById('sidebarOverlay').classList.toggle('show');
    }
    function closeSidebar() {
      document.getElementById('sidebar').classList.remove('mobile-open');
      document.getElementById('sidebarOverlay').classList.remove('show');
    }
  </script>
</body>
</html>
