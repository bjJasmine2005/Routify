<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <meta name="description" content="Manage Routify school transport - Dashboard.">
    <meta name="theme-color" content="#2563eb">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🚌</text></svg>">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        * { font-family: 'Inter', sans-serif; }
        #map { height: 320px; border-radius: 1rem; position: relative; z-index: 0; }
        .map-legend { position: absolute; bottom: 10px; right: 10px; z-index: 500; background: white; border: 1px solid #e2e8f0; border-radius: 10px; padding: 8px 12px; font-size: 11px; font-weight: 700; color: #475569; display: flex; flex-direction: column; gap: 5px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        .legend-row { display: flex; align-items: center; gap: 6px; }
        .legend-dot-blue { width: 10px; height: 10px; border-radius: 50%; background: #2563eb; flex-shrink: 0; }
        .legend-dot-purple { width: 10px; height: 10px; border-radius: 50%; background: #7c3aed; flex-shrink: 0; }
        .leaflet-pane, .leaflet-top, .leaflet-bottom { z-index: 1 !important; }
        .leaflet-control { z-index: 2 !important; }
        .sidebar-item { transition: all 0.15s ease; color: #64748b; }
        .sidebar-item:hover { background: rgba(37,99,235,0.08); color: #2563eb; }
        .sidebar-item.active { background: rgba(37,99,235,0.1); color: #2563eb; border-right: 3px solid #2563eb; font-weight: 600; }
        .stat-card { transition: transform 0.2s, box-shadow 0.2s; }
        .stat-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
        .pulse-dot { animation: pulse 2s infinite; }
        @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
        #sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(15,23,42,0.5); backdrop-filter: blur(4px); z-index: 40; }
        #sidebar-overlay.show { display: block; }
        #sidebar { transition: transform 0.3s ease; }
        @media (max-width: 768px) {
            #sidebar { position: fixed; top: 0; left: 0; bottom: 0; z-index: 50; transform: translateX(-100%); width: 280px !important; }
            #sidebar.open { transform: translateX(0); }
        }
        .tab-btn { transition: all 0.2s; }
        .tab-btn.active { background: #2563eb; color: white; }
        .tab-btn:not(.active) { background: #f1f5f9; color: #64748b; }
        .tab-panel { display: none; }
        .tab-panel.active { display: block; }
        .notice-card { border-left: 4px solid #f59e0b; }
        .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(15,23,42,0.5); backdrop-filter: blur(4px); z-index: 50; align-items: center; justify-content: center; }
        .modal-overlay.open { display: flex; }
    </style>
</head>
<body class="bg-slate-50 flex h-screen overflow-hidden">

    <div id="sidebar-overlay" onclick="closeSidebar()"></div>

    <!-- Sidebar -->
    <aside id="sidebar" class="w-64 bg-white border-r border-slate-200 flex flex-col flex-shrink-0">
        <div class="p-5 flex items-center justify-between border-b border-slate-100">
            <div class="flex items-center gap-2.5">
                <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center shadow-sm">
                    <i data-lucide="bus" class="w-4 h-4 text-white"></i>
                </div>
                <span class="text-lg font-bold tracking-tight text-slate-900">Routify</span>
            </div>
            <button onclick="closeSidebar()" class="md:hidden text-slate-400 hover:text-slate-600 p-1">
                <i data-lucide="x" class="w-5 h-5"></i>
            </button>
        </div>
        <div class="px-4 py-3 bg-blue-50 border-b border-blue-100">
            <p class="text-xs text-blue-600 font-semibold uppercase tracking-wide">Institution</p>
            <p class="text-sm font-bold text-slate-800 mt-0.5 truncate" id="inst-name">Loading...</p>
        </div>
        <nav class="flex-1 p-3 space-y-1 overflow-y-auto">
            <a href="/admin/dashboard" onclick="closeSidebar()" class="sidebar-item active flex items-center gap-3 px-3 py-2.5 rounded-xl">
                <i data-lucide="layout-dashboard" class="w-5 h-5 flex-shrink-0"></i><span class="text-sm">Dashboard</span>
            </a>
            <a href="/admin/routes" onclick="closeSidebar()" class="sidebar-item flex items-center gap-3 px-3 py-2.5 rounded-xl">
                <i data-lucide="map" class="w-5 h-5 flex-shrink-0"></i><span class="text-sm">Routes</span>
            </a>
            <a href="/admin/drivers" onclick="closeSidebar()" class="sidebar-item flex items-center gap-3 px-3 py-2.5 rounded-xl">
                <i data-lucide="users" class="w-5 h-5 flex-shrink-0"></i><span class="text-sm">Drivers</span>
            </a>
            <a href="/admin/students" onclick="closeSidebar()" class="sidebar-item flex items-center gap-3 px-3 py-2.5 rounded-xl">
                <i data-lucide="graduation-cap" class="w-5 h-5 flex-shrink-0"></i><span class="text-sm">Students</span>
            </a>
            <a href="/admin/vehicles" onclick="closeSidebar()" class="sidebar-item flex items-center gap-3 px-3 py-2.5 rounded-xl">
                <i data-lucide="truck" class="w-5 h-5 flex-shrink-0"></i><span class="text-sm">Vehicles</span>
            </a>
        </nav>
        <div class="p-3 border-t border-slate-100">
            <button onclick="logout()" class="sidebar-item flex items-center gap-3 px-3 py-2.5 rounded-xl w-full text-left hover:text-red-600 hover:bg-red-50">
                <i data-lucide="log-out" class="w-5 h-5 flex-shrink-0"></i><span class="text-sm">Logout</span>
            </button>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col overflow-hidden min-w-0">
        <!-- Header -->
        <header class="h-14 md:h-16 bg-white border-b border-slate-200 flex items-center justify-between px-4 md:px-8 flex-shrink-0">
            <div class="flex items-center gap-3">
                <button onclick="openSidebar()" class="md:hidden p-2 rounded-xl hover:bg-slate-100 transition text-slate-600">
                    <i data-lucide="menu" class="w-5 h-5"></i>
                </button>
                <div>
                    <h1 class="text-base md:text-lg font-bold text-slate-900">Fleet Dashboard</h1>
                    <p class="text-xs text-slate-500 hidden sm:block">Live tracking & management</p>
                </div>
            </div>
            <div class="flex items-center gap-2 md:gap-4">
                <div class="hidden sm:flex items-center gap-2 text-xs text-slate-500 bg-green-50 border border-green-100 px-3 py-1.5 rounded-full">
                    <span class="w-2 h-2 bg-green-500 rounded-full pulse-dot inline-block"></span> Live
                </div>
                <div class="w-8 h-8 md:w-9 md:h-9 bg-blue-600 rounded-full flex items-center justify-center text-white font-bold text-sm" id="user-avatar">A</div>
            </div>
        </header>

        <!-- Content -->
        <div class="flex-1 overflow-y-auto p-4 md:p-6">

            <!-- Institution Card -->
            <div id="inst-card" class="mb-4 bg-gradient-to-r from-blue-700 via-blue-600 to-indigo-600 text-white p-4 md:p-5 rounded-2xl shadow-lg shadow-blue-200 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-center backdrop-blur-sm">
                        <i data-lucide="building-2" class="w-5 h-5 text-white"></i>
                    </div>
                    <div>
                        <p class="text-blue-200 text-xs font-semibold uppercase tracking-widest">Institution</p>
                        <h2 class="text-base md:text-lg font-black tracking-tight" id="inst-full-name">Loading...</h2>
                    </div>
                </div>
                <div class="text-right hidden sm:block">
                    <p class="text-blue-200 text-xs">Admin Portal</p>
                    <p class="text-white text-xs font-semibold" id="inst-email-display"></p>
                </div>
            </div>

            <!-- Stats Grid -->
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3 md:gap-4 mb-5">
                <div class="stat-card bg-white p-4 md:p-5 rounded-2xl shadow-sm border border-slate-100">
                    <div class="flex items-center justify-between mb-2"><p class="text-xs text-slate-500 font-medium">Active Trips</p><div class="w-7 h-7 bg-blue-100 rounded-xl flex items-center justify-center"><i data-lucide="navigation" class="w-3.5 h-3.5 text-blue-600"></i></div></div>
                    <h3 class="text-xl md:text-2xl font-black text-slate-900" id="stat-active-trips">—</h3>
                </div>
                <div class="stat-card bg-white p-4 md:p-5 rounded-2xl shadow-sm border border-slate-100">
                    <div class="flex items-center justify-between mb-2"><p class="text-xs text-slate-500 font-medium">Routes</p><div class="w-7 h-7 bg-green-100 rounded-xl flex items-center justify-center"><i data-lucide="map" class="w-3.5 h-3.5 text-green-600"></i></div></div>
                    <h3 class="text-xl md:text-2xl font-black text-slate-900" id="stat-routes">—</h3>
                </div>
                <div class="stat-card bg-white p-4 md:p-5 rounded-2xl shadow-sm border border-slate-100">
                    <div class="flex items-center justify-between mb-2"><p class="text-xs text-slate-500 font-medium">Drivers</p><div class="w-7 h-7 bg-purple-100 rounded-xl flex items-center justify-center"><i data-lucide="users" class="w-3.5 h-3.5 text-purple-600"></i></div></div>
                    <h3 class="text-xl md:text-2xl font-black text-slate-900" id="stat-drivers">—</h3>
                </div>
                <div class="stat-card bg-white p-4 md:p-5 rounded-2xl shadow-sm border border-slate-100">
                    <div class="flex items-center justify-between mb-2"><p class="text-xs text-slate-500 font-medium">Students</p><div class="w-7 h-7 bg-orange-100 rounded-xl flex items-center justify-center"><i data-lucide="graduation-cap" class="w-3.5 h-3.5 text-orange-500"></i></div></div>
                    <h3 class="text-xl md:text-2xl font-black text-slate-900" id="stat-students">—</h3>
                </div>
                <div class="stat-card bg-white p-4 md:p-5 rounded-2xl shadow-sm border border-slate-100 col-span-2 sm:col-span-1">
                    <div class="flex items-center justify-between mb-2"><p class="text-xs text-slate-500 font-medium">Vehicles</p><div class="w-7 h-7 bg-cyan-100 rounded-xl flex items-center justify-center"><i data-lucide="truck" class="w-3.5 h-3.5 text-cyan-600"></i></div></div>
                    <h3 class="text-xl md:text-2xl font-black text-slate-900" id="stat-vehicles">—</h3>
                </div>
            </div>

            <!-- Map + Quick Actions -->
            <div class="grid lg:grid-cols-5 gap-4 md:gap-6 mb-5">
                <div class="lg:col-span-3 bg-white p-4 md:p-5 rounded-2xl shadow-sm border border-slate-100">
                    <div class="flex items-center justify-between mb-3">
                        <h3 class="font-bold text-slate-800 text-sm md:text-base">Live Fleet Map</h3>
                        <span class="text-xs text-slate-400" id="stop-count-label"></span>
                    </div>
                    <div style="position:relative">
                        <div id="map"></div>
                        <div class="map-legend">
                            <div class="legend-row"><div class="legend-dot-blue"></div>Active Bus</div>
                            <div class="legend-row"><div class="legend-dot-purple"></div>Student Stop</div>
                        </div>
                    </div>
                </div>
                <div class="lg:col-span-2 space-y-3">
                    <div class="bg-white p-4 md:p-5 rounded-2xl shadow-sm border border-slate-100">
                        <h3 class="font-bold text-slate-800 text-sm mb-3">Quick Actions</h3>
                        <div class="grid grid-cols-2 lg:grid-cols-1 gap-2">
                            <a href="/admin/drivers" class="flex items-center gap-3 p-3 bg-blue-50 rounded-xl hover:bg-blue-100 transition">
                                <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center flex-shrink-0"><i data-lucide="user-plus" class="w-4 h-4 text-white"></i></div>
                                <div class="min-w-0"><p class="text-sm font-semibold text-slate-800 truncate">Add Driver</p><p class="text-xs text-slate-500 hidden lg:block">Onboard a driver</p></div>
                            </a>
                            <a href="/admin/students" class="flex items-center gap-3 p-3 bg-green-50 rounded-xl hover:bg-green-100 transition">
                                <div class="w-8 h-8 bg-green-600 rounded-lg flex items-center justify-center flex-shrink-0"><i data-lucide="graduation-cap" class="w-4 h-4 text-white"></i></div>
                                <div class="min-w-0"><p class="text-sm font-semibold text-slate-800 truncate">Add Student</p><p class="text-xs text-slate-500 hidden lg:block">Register a student</p></div>
                            </a>
                            <a href="/admin/vehicles" class="flex items-center gap-3 p-3 bg-purple-50 rounded-xl hover:bg-purple-100 transition">
                                <div class="w-8 h-8 bg-purple-600 rounded-lg flex items-center justify-center flex-shrink-0"><i data-lucide="truck" class="w-4 h-4 text-white"></i></div>
                                <div class="min-w-0"><p class="text-sm font-semibold text-slate-800 truncate">Add Vehicle</p><p class="text-xs text-slate-500 hidden lg:block">Register a bus</p></div>
                            </a>
                            <button onclick="openNoticeModal()" class="flex items-center gap-3 p-3 bg-amber-50 rounded-xl hover:bg-amber-100 transition text-left w-full">
                                <div class="w-8 h-8 bg-amber-500 rounded-lg flex items-center justify-center flex-shrink-0"><i data-lucide="megaphone" class="w-4 h-4 text-white"></i></div>
                                <div class="min-w-0"><p class="text-sm font-semibold text-slate-800 truncate">Post Notice</p><p class="text-xs text-slate-500 hidden lg:block">Broadcast to parents</p></div>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Active Notices -->
            <div id="notices-section" class="mb-5 hidden">
                <div class="bg-amber-50 border border-amber-200 rounded-2xl p-4">
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-2">
                            <i data-lucide="megaphone" class="w-4 h-4 text-amber-600"></i>
                            <h3 class="font-bold text-amber-800 text-sm">Active Notices</h3>
                        </div>
                        <button onclick="openNoticeModal()" class="text-xs text-amber-700 font-bold hover:underline">+ New</button>
                    </div>
                    <div id="notices-list" class="space-y-2"></div>
                </div>
            </div>

            <!-- Tabs: Active Trips / Trip History -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
                <div class="p-4 md:p-5 border-b border-slate-100 flex items-center justify-between flex-wrap gap-3">
                    <div class="flex gap-2">
                        <button id="tab-active" onclick="switchTab('active')" class="tab-btn active text-xs font-bold px-4 py-2 rounded-xl">Active Trips</button>
                        <button id="tab-history" onclick="switchTab('history')" class="tab-btn text-xs font-bold px-4 py-2 rounded-xl">Trip History</button>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="text-xs text-slate-500 bg-slate-50 px-3 py-1 rounded-full" id="trips-count">No active trips</span>
                        <button id="export-csv-btn" onclick="exportHistoryCSV()" class="hidden text-xs bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold px-3 py-1.5 rounded-lg flex items-center gap-1.5 transition">
                            <i data-lucide="download" class="w-3 h-3"></i> Export CSV
                        </button>
                    </div>
                </div>

                <!-- Active Trips Panel -->
                <div id="panel-active" class="tab-panel active overflow-x-auto">
                    <table class="w-full text-left min-w-[500px]">
                        <thead class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wide">
                            <tr>
                                <th class="px-4 md:px-6 py-3.5 font-semibold">Bus / Route</th>
                                <th class="px-4 md:px-6 py-3.5 font-semibold">Driver</th>
                                <th class="px-4 md:px-6 py-3.5 font-semibold">Status</th>
                                <th class="px-4 md:px-6 py-3.5 font-semibold">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="trips-table-body" class="divide-y divide-slate-100 text-sm">
                            <tr id="no-trips-row">
                                <td colspan="4" class="px-6 py-10 text-center text-slate-400">
                                    <i data-lucide="bus" class="w-8 h-8 mx-auto mb-2 opacity-30"></i>
                                    <p class="text-sm">No active trips at the moment</p>
                                    <p class="text-xs mt-1 opacity-70">Trips appear here when drivers start them</p>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Trip History Panel -->
                <div id="panel-history" class="tab-panel overflow-x-auto">
                    <div id="history-loading" class="p-8 text-center text-slate-400">
                        <div class="w-6 h-6 border-2 border-blue-500 border-t-transparent rounded-full animate-spin mx-auto mb-2"></div>
                        <p class="text-sm">Loading history...</p>
                    </div>
                    <table class="w-full text-left min-w-[600px] hidden" id="history-table">
                        <thead class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wide">
                            <tr>
                                <th class="px-4 md:px-6 py-3.5 font-semibold">Date & Time</th>
                                <th class="px-4 md:px-6 py-3.5 font-semibold">Route</th>
                                <th class="px-4 md:px-6 py-3.5 font-semibold">Driver</th>
                                <th class="px-4 md:px-6 py-3.5 font-semibold">Duration</th>
                                <th class="px-4 md:px-6 py-3.5 font-semibold">Attendance</th>
                            </tr>
                        </thead>
                        <tbody id="history-table-body" class="divide-y divide-slate-100 text-sm"></tbody>
                    </table>
                    <div id="history-empty" class="hidden p-10 text-center text-slate-400">
                        <i data-lucide="clock" class="w-8 h-8 mx-auto mb-2 opacity-30"></i>
                        <p class="text-sm">No completed trips yet</p>
                    </div>
                </div>
            </div>

        </div>
    </main>

    <!-- Notice Modal -->
    <div id="notice-modal" class="modal-overlay" onclick="closeOnOverlay(event,'notice-modal')">
        <div class="bg-white rounded-3xl shadow-2xl w-full max-w-md p-8 mx-4">
            <div class="flex items-center justify-between mb-6">
                <div>
                    <h2 class="text-xl font-bold text-slate-900">Post a Notice</h2>
                    <p class="text-sm text-slate-500 mt-0.5">Parents will see this on their portal</p>
                </div>
                <button onclick="closeModal('notice-modal')" class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-slate-100">
                    <i data-lucide="x" class="w-4 h-4 text-slate-500"></i>
                </button>
            </div>
            <form id="notice-form" class="space-y-4">
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Title *</label>
                    <input id="notice-title" type="text" required class="w-full border-2 border-slate-200 rounded-xl px-4 py-3 text-sm focus:border-amber-500 focus:outline-none" placeholder="e.g. Bus delayed today">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Message *</label>
                    <textarea id="notice-message" rows="3" required class="w-full border-2 border-slate-200 rounded-xl px-4 py-3 text-sm focus:border-amber-500 focus:outline-none resize-none" placeholder="e.g. The bus will arrive 20 minutes late due to traffic on Main Road."></textarea>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Expires (optional)</label>
                    <input id="notice-expires" type="datetime-local" class="w-full border-2 border-slate-200 rounded-xl px-4 py-3 text-sm focus:border-amber-500 focus:outline-none">
                </div>
                <div class="flex gap-3 pt-2">
                    <button type="button" onclick="closeModal('notice-modal')" class="flex-1 py-3 border-2 border-slate-200 rounded-xl text-sm font-semibold text-slate-700 hover:bg-slate-50">Cancel</button>
                    <button type="submit" class="flex-1 py-3 bg-amber-500 text-white rounded-xl text-sm font-bold hover:bg-amber-600 flex items-center justify-center gap-2">
                        <i data-lucide="send" class="w-4 h-4"></i> Post Notice
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        lucide.createIcons();

        const user = JSON.parse(localStorage.getItem('routify_user') || '{}');
        const token = localStorage.getItem('routify_token');

        if (!token) window.location.href = '/login';
        if (user.name) {
            document.getElementById('user-avatar').textContent = user.name.charAt(0).toUpperCase();
            document.getElementById('inst-name').textContent = user.name;
        }

        async function loadInstInfo() {
            if (!token) return;
            try {
                const res = await fetch('/api/institution', { headers: { 'Authorization': `Bearer ${token}` } });
                if (res.ok) {
                    const data = await res.json();
                    document.getElementById('inst-full-name').textContent = data.name || user.name;
                    document.getElementById('inst-email-display').textContent = data.email || '';
                    document.getElementById('inst-name').textContent = data.name || user.name;
                } else {
                    document.getElementById('inst-full-name').textContent = user.name || 'Your Institution';
                }
            } catch { document.getElementById('inst-full-name').textContent = user.name || 'Your Institution'; }
        }
        loadInstInfo();

        function logout() { localStorage.removeItem('routify_token'); localStorage.removeItem('routify_user'); window.location.href = '/login'; }
        function openSidebar() { document.getElementById('sidebar').classList.add('open'); document.getElementById('sidebar-overlay').classList.add('show'); }
        function closeSidebar() { document.getElementById('sidebar').classList.remove('open'); document.getElementById('sidebar-overlay').classList.remove('show'); }
        function openNoticeModal() { document.getElementById('notice-form').reset(); document.getElementById('notice-modal').classList.add('open'); }
        function closeModal(id) { document.getElementById(id).classList.remove('open'); }
        function closeOnOverlay(e, id) { if (e.target === document.getElementById(id)) closeModal(id); }

        // Load Stats
        async function loadStats() {
            if (!token) return;
            try {
                const res = await fetch('/api/dashboard/stats', { headers: { 'Authorization': `Bearer ${token}` } });
                const data = await res.json();
                if (res.ok) {
                    document.getElementById('stat-active-trips').textContent = data.activeTrips;
                    document.getElementById('stat-routes').textContent = data.totalRoutes;
                    document.getElementById('stat-drivers').textContent = data.totalDrivers;
                    document.getElementById('stat-students').textContent = data.totalStudents;
                    document.getElementById('stat-vehicles').textContent = data.totalVehicles;
                }
            } catch {}
        }
        loadStats();
        setInterval(loadStats, 15000);

        // Map — declared here so loadActiveTrips & loadStudentStops can safely use it
        const map = L.map('map').setView([20.5937, 78.9629], 5);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap' }).addTo(map);
        const markers = {};

        // Load Active Trips
        async function loadActiveTrips() {
            if (!token) return;
            try {
                const res = await fetch('/api/trips/active', { headers: { 'Authorization': `Bearer ${token}` } });
                const trips = await res.json();
                if (res.ok) {
                    trips.forEach(t => {
                        if (t.current_lat && t.current_lng) {
                            const busIcon = L.divIcon({
                                className: '',
                                html: `<div style="background:#2563eb;color:white;padding:4px 10px;border-radius:12px;font-size:11px;font-weight:800;white-space:nowrap;box-shadow:0 3px 10px rgba(37,99,235,0.45);border:2px solid white;">🚌 ${t.busName || 'Bus'}</div>`,
                                iconAnchor: [28, 14]
                            });
                            markers[t._id] = L.marker([t.current_lat, t.current_lng], { icon: busIcon }).addTo(map);
                            map.setView([t.current_lat, t.current_lng], 13);
                        }
                        addTripRow({ tripId: t._id, busName: t.busName || 'Bus', driverName: t.driver_name, routeName: t.route_id });
                    });
                }
            } catch (err) { console.error('Failed to load active trips:', err); }
        }
        loadActiveTrips();

        // Load Student Stop Markers
        const stopMarkers = {};
        async function loadStudentStops() {
            if (!token) return;
            try {
                const res = await fetch('/api/students', { headers: { 'Authorization': `Bearer ${token}` } });
                if (!res.ok) return;
                const students = await res.json();
                let pinned = 0;
                students.forEach(s => {
                    if (!s.pickup_lat || !s.pickup_lng) return;
                    pinned++;
                    const icon = L.divIcon({
                        className: '',
                        html: `<div style="background:#7c3aed;color:white;padding:3px 9px;border-radius:12px;font-size:10px;font-weight:800;white-space:nowrap;box-shadow:0 2px 8px rgba(124,58,237,0.4);border:2px solid white;">${s.name.split(' ')[0]}</div>`,
                        iconAnchor: [30, 12]
                    });
                    const mk = L.marker([s.pickup_lat, s.pickup_lng], { icon })
                        .bindTooltip(`${s.name}<br><span style="font-size:11px;color:#94a3b8">${s.pickup_location || ''}</span>`, { direction: 'top' })
                        .addTo(map);
                    stopMarkers[s._id || s.id] = mk;
                });
                const lbl = document.getElementById('stop-count-label');
                if (lbl) lbl.textContent = pinned > 0 ? `${pinned} stop${pinned !== 1 ? 's' : ''} pinned` : 'No stops pinned yet';
            } catch(e) { console.error('Failed to load student stops:', e); }
        }
        loadStudentStops();

        // Socket.io
        const socket = io();
        if (user.institutionId) socket.emit('join-institution', user.institutionId);

        socket.on('location:updated', (data) => {
            const { tripId, lat, lng, busName } = data;
            const busIcon = L.divIcon({ className: '', html: `<div style="background:#2563eb;color:white;padding:3px 8px;border-radius:10px;font-size:11px;font-weight:700;white-space:nowrap;box-shadow:0 2px 8px rgba(37,99,235,0.4)">🚌 ${busName || 'Bus'}</div>`, iconAnchor: [24, 12] });
            if (!markers[tripId]) {
                markers[tripId] = L.marker([lat, lng], { icon: busIcon }).addTo(map);
            } else { markers[tripId].setLatLng([lat, lng]); }
            map.panTo([lat, lng]);
        });

        socket.on('trip:started', (data) => { addTripRow(data); loadStats(); });
        socket.on('trip:ended', (data) => {
            const { tripId } = data;
            if (markers[tripId]) { map.removeLayer(markers[tripId]); delete markers[tripId]; }
            removeTripRow(tripId);
            loadStats();
            // Reload history if visible
            if (document.getElementById('panel-history').classList.contains('active')) loadTripHistory();
        });

        function addTripRow(data) {
            const body = document.getElementById('trips-table-body');
            document.getElementById('no-trips-row')?.remove();
            const row = document.createElement('tr');
            row.id = `trip-${data.tripId}`;
            row.innerHTML = `
                <td class="px-4 md:px-6 py-4">
                    <div class="font-semibold text-slate-800 text-sm">${data.busName || 'Bus'}</div>
                    <div class="text-xs text-slate-500">${data.routeName || data.tripId?.substr(0, 8)}</div>
                </td>
                <td class="px-4 md:px-6 py-4 text-slate-700 text-sm">${data.driverName || '—'}</td>
                <td class="px-4 md:px-6 py-4">
                    <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-green-100 text-green-700 text-xs font-bold rounded-full">
                        <span class="w-1.5 h-1.5 bg-green-500 rounded-full pulse-dot"></span>LIVE
                    </span>
                </td>
                <td class="px-4 md:px-6 py-4">
                    <button onclick="focusBus('${data.tripId}')" class="text-blue-600 text-xs font-semibold hover:underline">Track →</button>
                </td>`;
            body.appendChild(row);
            document.getElementById('trips-count').textContent = `${body.querySelectorAll('tr:not(#no-trips-row)').length} active`;
        }

        function removeTripRow(tripId) {
            document.getElementById(`trip-${tripId}`)?.remove();
            const body = document.getElementById('trips-table-body');
            if (!body.querySelector('tr:not(#no-trips-row)')) {
                body.innerHTML = `<tr id="no-trips-row"><td colspan="4" class="px-6 py-10 text-center text-slate-400"><i data-lucide="bus" class="w-8 h-8 mx-auto mb-2 opacity-30"></i><p class="text-sm">No active trips at the moment</p></td></tr>`;
                lucide.createIcons();
                document.getElementById('trips-count').textContent = 'No active trips';
            }
        }

        function focusBus(tripId) { if (markers[tripId]) map.panTo(markers[tripId].getLatLng(), { animate: true }); }

        // ─── Tabs ─────────────────────────────────────────────────────────────
        function switchTab(tab) {
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
            document.getElementById(`tab-${tab}`).classList.add('active');
            document.getElementById(`panel-${tab}`).classList.add('active');

            if (tab === 'history') {
                document.getElementById('export-csv-btn').classList.remove('hidden');
                loadTripHistory();
            } else {
                document.getElementById('export-csv-btn').classList.add('hidden');
                document.getElementById('trips-count').textContent = document.querySelectorAll('#trips-table-body tr:not(#no-trips-row)').length + ' active';
            }
        }

        let historyData = [];
        async function loadTripHistory() {
            const loadingEl = document.getElementById('history-loading');
            const tableEl = document.getElementById('history-table');
            const emptyEl = document.getElementById('history-empty');
            loadingEl.classList.remove('hidden');
            tableEl.classList.add('hidden');
            emptyEl.classList.add('hidden');

            try {
                const res = await fetch('/api/trips/history?limit=30', { headers: { 'Authorization': `Bearer ${token}` } });
                const data = await res.json();
                historyData = data.trips || [];
                loadingEl.classList.add('hidden');

                if (historyData.length === 0) {
                    emptyEl.classList.remove('hidden');
                    document.getElementById('trips-count').textContent = '0 completed';
                    return;
                }

                tableEl.classList.remove('hidden');
                document.getElementById('trips-count').textContent = `${data.total} completed`;

                const tbody = document.getElementById('history-table-body');
                tbody.innerHTML = historyData.map(t => {
                    const started = t.started_at ? new Date(t.started_at) : null;
                    const dateStr = started ? started.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '—';
                    const timeStr = started ? started.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) : '';
                    const dur = t.duration_seconds ? `${Math.floor(t.duration_seconds/60)}m` : '—';
                    return `
                        <tr class="hover:bg-slate-50">
                            <td class="px-4 md:px-6 py-4">
                                <div class="font-semibold text-slate-800 text-sm">${dateStr}</div>
                                <div class="text-xs text-slate-400">${timeStr}</div>
                            </td>
                            <td class="px-4 md:px-6 py-4 text-sm text-slate-700 font-medium">${t.route_name || '—'}</td>
                            <td class="px-4 md:px-6 py-4 text-sm text-slate-600">${t.driver_name || '—'}</td>
                            <td class="px-4 md:px-6 py-4 text-sm text-slate-600">${dur}</td>
                            <td class="px-4 md:px-6 py-4">
                                <div class="flex items-center gap-2 flex-wrap">
                                    ${t.picked_up > 0 ? `<span class="inline-flex items-center gap-1 px-2 py-0.5 bg-green-100 text-green-700 text-[11px] font-bold rounded-full">🚌 ${t.picked_up} picked</span>` : ''}
                                    ${t.dropped_off > 0 ? `<span class="inline-flex items-center gap-1 px-2 py-0.5 bg-purple-100 text-purple-700 text-[11px] font-bold rounded-full">🏠 ${t.dropped_off} dropped</span>` : ''}
                                    ${t.absent > 0 ? `<span class="inline-flex items-center gap-1 px-2 py-0.5 bg-red-100 text-red-600 text-[11px] font-bold rounded-full">❌ ${t.absent} absent</span>` : ''}
                                    ${(t.picked_up === 0 && t.dropped_off === 0 && t.absent === 0) ? `<span class="text-[11px] text-slate-400">No data</span>` : ''}
                                </div>
                            </td>
                        </tr>`;
                }).join('');
            } catch (e) { 
                loadingEl.classList.add('hidden');
                emptyEl.classList.remove('hidden');
            }
        }

        // Export history as CSV
        function exportHistoryCSV() {
            if (historyData.length === 0) return;
            const headers = ['Date', 'Time', 'Route', 'Driver', 'Duration (min)', 'Picked Up', 'Dropped Off', 'Absent'];
            const rows = historyData.map(t => {
                const started = t.started_at ? new Date(t.started_at) : null;
                return [
                    started ? started.toLocaleDateString() : '',
                    started ? started.toLocaleTimeString() : '',
                    t.route_name || '', t.driver_name || '',
                    t.duration_seconds ? Math.floor(t.duration_seconds/60) : '',
                    t.picked_up || 0, t.dropped_off || 0, t.absent || 0
                ];
            });
            const csv = [headers, ...rows].map(r => r.map(v => `"${v}"`).join(',')).join('\n');
            const blob = new Blob([csv], { type: 'text/csv' });
            const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'routify-trip-history.csv'; a.click();
        }

        // ─── Notices ──────────────────────────────────────────────────────────
        async function loadNotices() {
            try {
                const res = await fetch('/api/notices', { headers: { 'Authorization': `Bearer ${token}` } });
                const notices = await res.json();
                const section = document.getElementById('notices-section');
                const list = document.getElementById('notices-list');
                if (notices.length === 0) { section.classList.add('hidden'); return; }
                section.classList.remove('hidden');
                list.innerHTML = notices.map(n => `
                    <div class="notice-card bg-white rounded-xl p-3 flex items-start justify-between gap-3">
                        <div>
                            <p class="text-sm font-bold text-slate-800">${n.title}</p>
                            <p class="text-xs text-slate-500 mt-0.5">${n.message}</p>
                            ${n.expires_at ? `<p class="text-[10px] text-amber-600 mt-1 font-semibold">Expires: ${new Date(n.expires_at).toLocaleDateString()}</p>` : ''}
                        </div>
                        <button onclick="dismissNotice('${n._id}')" class="text-slate-300 hover:text-red-500 transition flex-shrink-0">
                            <i data-lucide="x" class="w-4 h-4"></i>
                        </button>
                    </div>`).join('');
                lucide.createIcons();
            } catch {}
        }

        async function dismissNotice(id) {
            try {
                await fetch(`/api/notices/${id}`, { method: 'DELETE', headers: { 'Authorization': `Bearer ${token}` } });
                loadNotices();
            } catch {}
        }

        document.getElementById('notice-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = e.target.querySelector('[type="submit"]');
            btn.disabled = true; btn.textContent = 'Posting...';
            try {
                const res = await fetch('/api/notices', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                    body: JSON.stringify({
                        title: document.getElementById('notice-title').value,
                        message: document.getElementById('notice-message').value,
                        expires_at: document.getElementById('notice-expires').value || undefined
                    })
                });
                if (res.ok) {
                    closeModal('notice-modal');
                    loadNotices();
                }
            } catch {}
            btn.disabled = false; btn.innerHTML = '<i data-lucide="send" class="w-4 h-4"></i> Post Notice'; lucide.createIcons();
        });

        loadNotices();
        setInterval(loadNotices, 30000);
    </script>
</body>
</html>
